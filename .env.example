PROJECT_NAME="Medicore Hospital Management System"
API_V1_STR="/api/v1"
SECRET_KEY="your-super-secret-key-change-this-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL="postgresql+asyncpg://postgres:yourpassword@localhost:5432/medicore_hms"

# YARA malware scanning
YARA_ENABLED=true
YARA_RULES_PATH=app/security/yara_rules

# Gemini AI — document extraction (primary path)
# Get free key: https://aistudio.google.com/apikey
# Falls back to PyMuPDF+regex if not set or quota exceeded
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=models/gemini-2.0-flash
